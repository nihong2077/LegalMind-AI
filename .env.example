# ============================================
# LegalMind AI 环境变量模板
# 复制此文件为 .env 并填入真实值
# ⚠️  绝对不要将 .env 提交到 Git
# ============================================

# 项目配置
PROJECT_NAME=LegalMind AI
API_PREFIX=/api/v1

# 数据库配置
POSTGRES_PASSWORD=legalmind_secure_2024
DATABASE_URL=postgresql+asyncpg://legalmind:legalmind_secure_2024@postgres:5432/legalmind

# Qdrant 配置
QDRANT_URL=http://qdrant:6333

# --- FastAPI ---
JWT_SECRET_KEY=change-me-in-production-use-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# 限流配置
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# --- LiteLLM Proxy ---
LITELLM_MASTER_KEY=sk-litellm-master-change-me
LITELLM_VIRTUAL_KEY=sk-litellm-virtual-change-me
LITELLM_DB_PASSWORD=litellm_secure_2024

# --- LLM API Keys（仅 LiteLLM Proxy 使用） ---
# 本地 vLLM 服务的 API Key（如无需鉴权可留空）
VLLM_API_KEY=sk-local-vllm
# DeepSeek 云端 API Key
DEEPSEEK_API_KEY=
# OpenAI API Key
OPENAI_API_KEY=

